# ── RPC endpoints (required) ───────────────────────────────────────────────────
# The Ankr public endpoints are NOT used as a fallback — they require an API key.
# If these vars are unset, viem falls back to the chain's built-in public RPC
# (rpc.sepolia.org / cloudflare-eth.com), which may be rate-limited.
# Set your own for reliable access.
#
# Free options that don't require auth:
#   PublicNode:  https://ethereum-sepolia-rpc.publicnode.com
#                https://ethereum-rpc.publicnode.com
#
# Free options with API key (generous free tier):
#   Alchemy:     https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
#                https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
#   Infura:      https://sepolia.infura.io/v3/YOUR_KEY
#                https://mainnet.infura.io/v3/YOUR_KEY

NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_MAINNET_RPC_URL=

# ── WalletConnect ──────────────────────────────────────────────────────────────
# Required for WalletConnect wallet connections (mobile wallets via QR).
# Injected wallets (MetaMask, Coinbase Wallet) work without this.
# Get a free projectId at https://cloud.walletconnect.com

NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
